# ─────────────────────────────────────────────────────────────
# 三十六贱笑 · 环境变量样例
# 复制为 .env 后填写真实值；.env 应进 .gitignore，绝不入仓
# 配置语义见 src/sanshiliu/foundation/config.py
# ─────────────────────────────────────────────────────────────

# ── LLM（OpenAI 兼容标准子集） ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# ── 运行时 ──
# 数据目录：sqlite、日志、jsonl 落盘位置（用户级 ~/.sanshiliu，项目级 ./data）
SANSHILIU_DATA_DIR=./data
# 上下文最大 token 数（命中阈值触发 compact）
SANSHILIU_MAX_CONTEXT_TOKENS=128000
# 日志级别：DEBUG / INFO / WARNING / ERROR
SANSHILIU_LOG_LEVEL=INFO
# Dashboard 首次进入密码；为空时不启用面板门禁
SANSHILIU_DASHBOARD_PASSWORD=

# Added by sanshiliu setup_wizard
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_ACCOUNT_STORE=C:\Users\skad\Desktop\cc\jx-agent\data\wechat-account.json
