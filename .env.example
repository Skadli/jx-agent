# ─────────────────────────────────────────────────────────────
# 三十六贱笑 · 环境变量样例
# 复制为 .env 后填写真实值；.env 应进 .gitignore，绝不入仓
# 配置语义见 src/sanshiliu/foundation/config.py
# ─────────────────────────────────────────────────────────────

# ── LLM（OpenAI 兼容标准子集） ──
# 走官方 OpenAI：base_url 留空或填 https://api.openai.com/v1
# 走 DeepSeek：base_url=https://api.deepseek.com/v1
# 走 GLM/通义/OneAPI/Ollama 等任意 OpenAI 兼容后端：填对应 base_url
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 运行时 ──
# 数据目录：sqlite、日志、jsonl 落盘位置（用户级 ~/.sanshiliu，项目级 ./data）
SANSHILIU_DATA_DIR=./data
# 上下文最大 token 数（命中阈值触发 compact）
SANSHILIU_MAX_CONTEXT_TOKENS=128000
# 日志级别：DEBUG / INFO / WARNING / ERROR
SANSHILIU_LOG_LEVEL=INFO

# ── 通道开关（Phase 4 启用） ──
SANSHILIU_WECHAT_ENABLED=false
SANSHILIU_WEB_ENABLED=false
SANSHILIU_WEB_PORT=9527

# ── iLink 微信 Bot（Hermes QR，推荐） ──
# 首次运行 python -m sanshiliu setup 时，如果没有 WEIXIN_ACCOUNT_ID/WEIXIN_TOKEN，
# 会拉取 iLink Bot 二维码；扫码确认后自动写入这些字段并保存账号缓存。
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_ACCOUNT_STORE=data/wechat-account.json
WEIXIN_QR_FILE=data/wechat-login-qr.svg
WEIXIN_QR_LOGIN=true
WEIXIN_QR_OPEN_FILE=true
WEIXIN_QR_BOT_TYPE=3
WEIXIN_QR_TIMEOUT_SECONDS=480

# 白名单：空集合 = 一律拒绝；调试可填 *，生产建议填逗号分隔 wxid
SANSHILIU_WECHAT_WHITELIST=

# ── 旧本地 iLink webhook 兼容模式（可选） ──
ILINK_BASE_URL=http://127.0.0.1:8080
ILINK_API_KEY=
ILINK_WEBHOOK_SECRET=
