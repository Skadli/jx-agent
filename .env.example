# === LLM 主后端（OpenAI 兼容协议，必填）===
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# === 通道开关（默认 REPL 启用；其他默认关）===
# SANSHILIU_WEB_ENABLED=false
# SANSHILIU_WEB_PORT=9527
# SANSHILIU_WECHAT_ENABLED=false
# SANSHILIU_DASHBOARD_PASSWORD=

# === 长期记忆 ===
# SANSHILIU_MEMORY_ENABLED=true
# SANSHILIU_AUTO_EXTRACT_ENABLED=false   # 每轮多调 LLM 自动抽记忆（费 token）
# SANSHILIU_MEMDIR_DIR=./memdir
# SANSHILIU_DREAM_SCHEDULER_ENABLED=false   # serve 模式下每天定时检查做梦闸门
# SANSHILIU_DREAM_SCHEDULER_HOUR=3          # 定时器醒来的小时（0-23，local time）
# SANSHILIU_DREAM_SCHEDULER_MIN_SESSIONS=3  # 距上次做梦后新增 session 达此值才放行

# === 成长 scheduler（数字分身从 5 岁每天做成长梦、每梦跨 1 年、满 30 岁定格）===
# SANSHILIU_GROWTH_ENABLED=false              # 总开关；关=全局停（也是自动装 skill 的 kill-switch）
# SANSHILIU_GROWTH_HOUR=3                      # 成长定时器醒来的小时（0-23，local time）
# SANSHILIU_GROWTH_YEARS_PER_CHAPTER=1         # 每章成长梦跨多少年（默认 1 年/章 → 共 25 章）
# SANSHILIU_GROWTH_START_AGE=5                 # 成长起点年龄（原三十六贱笑起点）
# SANSHILIU_GROWTH_END_AGE=30                  # 成长终点年龄；跑满即定格
# SANSHILIU_SKILL_INSTALL_TIMEOUT_SEC=60      # 成长 phase-2 单次装 skill 的 bash 硬超时（秒）
# SANSHILIU_SKILL_INSTALL_PREWARM=true        # serve 启动预热 npx 缓存（消除 3am 冷拉/无 TTY 挂死）

# === 工具 / Skills ===
# SANSHILIU_TOOLS_ENABLED=true
# SANSHILIU_SKILLS_ENABLED=true
# TAVILY_API_KEY=                        # 缺则 web_search 走 DuckDuckGo HTML 兜底

# === 安全权限 + 上下文 + 日志 ===
# SANSHILIU_SECURITY_ENABLED=true        # 关掉后所有工具直接放行
# SANSHILIU_MAX_CONTEXT_TOKENS=128000
# SANSHILIU_COMPACT_THRESHOLD_RATIO=0.8
# SANSHILIU_LOG_LEVEL=INFO               # DEBUG / INFO / WARNING / ERROR

# === 豆包 vision-pro（开启后图片场景路由到此后端；缺则纯文本走 OPENAI_*）===
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=doubao-seed-2-0-pro-260215
# SANSHILIU_MULTIMODAL_MAX_IMAGES=4
# SANSHILIU_MULTIMODAL_MAX_IMAGE_BYTES=5242880

# === iLink 官方 Bot（推荐：扫码登录方式）===
# WEIXIN_ACCOUNT_ID=
# WEIXIN_TOKEN=
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
# WEIXIN_POLL_TIMEOUT_MS=35000
# WEIXIN_POLL_INTERVAL_MS=1000

# === iLink Webhook 路径（备选：HMAC 签名验证）===
# ILINK_BASE_URL=http://127.0.0.1:8080
# ILINK_API_KEY=
# ILINK_WEBHOOK_SECRET=
# ILINK_SIGNATURE_HEADER=X-iLink-Signature

# === 微信白名单/黑名单/合并窗口 ===
# SANSHILIU_WECHAT_WHITELIST=             # CSV wxid，空 = 允许所有
# SANSHILIU_WECHAT_INPUT_BLACKLIST=       # CSV 关键词
# SANSHILIU_WECHAT_OUTPUT_BLACKLIST=      # CSV 关键词
# SANSHILIU_WECHAT_MERGE_WINDOW_MS=0
# SANSHILIU_WECHAT_MERGE_WINDOW_MEDIA_MS=5000

# === 路径配置（一般不动）===
# SANSHILIU_DATA_DIR=./data
# SANSHILIU_HOME_DIR=~/.sanshiliu
# SANSHILIU_PERSONA_DIR=./persona
# SANSHILIU_PROMPTS_DIR=./prompts
# SANSHILIU_SKILLS_DIR_PROJECT=./.sanshiliu/skills
# SANSHILIU_SKILLS_DIR_GLOBAL=~/.sanshiliu/skills   # 用户级全局 skills（跨项目共享，缺省随 HOME_DIR）；skill-installer 默认装这里
# SANSHILIU_SKILLS_DIR_REPO=./skills
